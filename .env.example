# =============================================================================
#  ISP-CRM Environment Variables — COPY TO .env AND FILL IN VALUES
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=isp_crm
POSTGRES_USER=isp_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASS_32CHARS

# --- FreeRADIUS ---
RADIUS_SECRET=CHANGE_ME_RADIUS_SECRET

# --- Backend API ---
NODE_ENV=production
API_PORT=4000
JWT_SECRET=CHANGE_ME_JWT_SECRET_64_CHARS_MINIMUM_PLEASE
JWT_EXPIRES_IN=8h

# --- AES-256 Encryption Key (for router passwords stored in DB) ---
# Must be exactly 32 characters (256 bits)
AES_KEY=CHANGE_ME_32CHAR_AES_KEY_HERE!!!
AES_IV_LENGTH=16

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_API_TOKEN=your_meta_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id

# --- MikroTik API Defaults ---
MIKROTIK_API_PORT=8729
MIKROTIK_USE_TLS=true

# --- Frontend ---
VITE_API_BASE_URL=https://yourdomain.com/api

# --- Domain & SSL ---
DOMAIN=yourdomain.com
CERTBOT_EMAIL=admin@yourdomain.com

# --- Backup ---
BACKUP_RETENTION_DAYS=30
